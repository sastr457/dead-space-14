<BoxContainer
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Orientation="Vertical"
    HorizontalExpand="True"
    VerticalExpand="True"
    SeparationOverride="6">
    <!-- DS14-start -->
    <OutputPanel Name="TextOutput"
                 VerticalExpand="True"
                 StyleClasses="DS14MenuTextArea" />
    <RichTextLabel Name="TypingIndicator"
                   Access="Public" />
    <HistoryLineEdit Name="SenderLineEdit"
                     StyleClasses="DS14MenuInput" />
    <RichTextLabel Name="RelayedToDiscordLabel"
                   Access="Public"
                   Visible="False" />
    <!-- DS14-end -->
</BoxContainer>
