<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="Loading..."
                      MinSize="400 200">
    <!-- DS14-start -->
    <PanelContainer StyleClasses="DS14MenuShell">
        <PanelContainer StyleClasses="DS14MenuPanelDark">
            <BoxContainer Orientation="Vertical"
                          SeparationOverride="8">
                <PanelContainer StyleClasses="DS14MenuInset"
                                HorizontalExpand="True"
                                VerticalExpand="True">
                    <TextEdit Name="NoteTextEdit"
                              Access="Public"
                              HorizontalExpand="True"
                              VerticalExpand="True"
                              StyleClasses="DS14MenuTextArea" />
                </PanelContainer>
                <BoxContainer Orientation="Horizontal"
                              HorizontalExpand="True"
                              SeparationOverride="6">
                    <Label Name="ExpiryLabel"
                           Text="{Loc admin-note-editor-expiry-label}"
                           Visible="False"
                           StyleClasses="DS14MenuProfileLabel" />
                    <HistoryLineEdit Name="ExpiryLineEdit"
                                     PlaceHolder="{Loc admin-note-editor-expiry-placeholder}"
                                     Visible="False"
                                     HorizontalExpand="True"
                                     StyleClasses="DS14MenuInput" />
                    <OptionButton Name="ExpiryLengthDropdown"
                                  Visible="False"
                                  StyleClasses="DS14MenuProfileControl" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal"
                              HorizontalExpand="True"
                              SeparationOverride="6">
                    <OptionButton Name="TypeOption"
                                  HorizontalAlignment="Center"
                                  StyleClasses="DS14MenuProfileControl" />
                    <OptionButton Name="SeverityOption"
                                  HorizontalAlignment="Center"
                                  StyleClasses="DS14MenuProfileControl" />
                    <CheckBox Name="SecretCheckBox"
                              Text="{Loc admin-note-editor-secret}"
                              ToolTip="{Loc admin-note-editor-secret-tooltip}"
                              StyleClasses="DS14MenuProfileControl" />
                    <CheckBox Name="PermanentCheckBox"
                              Pressed="True"
                              Text="{Loc admin-note-editor-expiry-checkbox}"
                              ToolTip="{Loc admin-note-editor-expiry-checkbox-tooltip}"
                              StyleClasses="DS14MenuProfileControl" />
                    <Control HorizontalExpand="True" />
                    <Button Name="SubmitButton"
                            Access="Public"
                            Text="{Loc admin-note-editor-submit}"
                            HorizontalAlignment="Right"
                            StyleClasses="DS14MenuProfileControl" />
                </BoxContainer>
            </BoxContainer>
        </PanelContainer>
    </PanelContainer>
    <!-- DS14-end -->
</controls:FancyWindow>
