<BoxContainer xmlns="https://spacestation14.io" Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" MinSize="100 100">
    <!-- DS14-start -->
    <Control HorizontalExpand="True" VerticalExpand="True" HorizontalAlignment="Stretch">
        <PanelContainer StyleClasses="DS14MenuInset"
                        HorizontalExpand="True"
                        VerticalExpand="True">
            <ScrollContainer Name="Scroll" HScrollEnabled="False" HorizontalExpand="True" VerticalExpand="True">
                <BoxContainer Name="RulesContainer" VerticalExpand="True" Margin="0 0 5 0"/>
            </ScrollContainer>
        </PanelContainer>
        <BoxContainer Margin="0 0 15 0"
                      HorizontalExpand="True"
                      HorizontalAlignment="Right"
                      SeparationOverride="4">
            <Button Name="BackButton"
                    Text="{Loc 'ui-rules-button-back'}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    StyleClasses="DS14MenuProfileControl"/>
            <Button Name="HomeButton"
                    Text="{Loc 'ui-rules-button-home'}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    StyleClasses="DS14MenuProfileControl"/>
            <Button Name="WikiButton"
                    Access="Public"
                    Text="{Loc 'ui-escape-wiki'}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    StyleClasses="DS14MenuProfileControl"/>
        </BoxContainer>
    </Control>
    <!-- DS14-end -->
</BoxContainer>
